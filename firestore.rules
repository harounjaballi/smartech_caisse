rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all safety gate
    match /{document=**} {
      allow read, write: if false;
    }

    // --- HELPER FUNCTIONS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUserActive() {
      return true;
    }

    // Vérifie si l'utilisateur connecté est l'owner direct OU un collaborateur du même tenant
    function hasAccess(ownerId) {
      return isAuthenticated() && (
        // Cas 1 : l'utilisateur est lui-même l'owner (admin)
        request.auth.uid == ownerId ||
        // Cas 2 : c'est un collaborateur dont le document user existe avec le bon ownerId
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('ownerId', '') == ownerId)
      );
    }

    // --- MATCH BLOCKS FOR COLLECTIONS ---

    match /users/{userId} {
      allow create: if isAuthenticated() && request.auth.uid == userId &&
        request.resource.data.uid == userId &&
        request.resource.data.role == "admin" &&
        request.resource.data.status == "active" &&
        request.resource.data.ownerId == userId;

      allow read: if isAuthenticated() && request.auth.uid == userId;

      allow read: if isAuthenticated() && request.auth.uid != userId &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('ownerId', '') == get(/databases/$(database)/documents/users/$(userId)).data.get('ownerId', '') ||
          request.auth.uid == get(/databases/$(database)/documents/users/$(userId)).data.get('creatorId', '')
        );

      allow update: if isAuthenticated() && request.auth.uid == userId &&
        request.resource.data.role == resource.data.get('role', 'user') && 
        request.resource.data.status == resource.data.get('status', 'active') &&
        request.resource.data.ownerId == resource.data.get('ownerId', userId);

      allow update: if isAuthenticated() && request.auth.uid != userId &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('ownerId', '') == resource.data.get('ownerId', '') ||
          request.auth.uid == resource.data.get('creatorId', '')
        );

      allow delete: if isAuthenticated() && request.auth.uid != userId &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('ownerId', '') == resource.data.get('ownerId', '') ||
          request.auth.uid == resource.data.get('creatorId', '')
        );
    }

    match /products/{productId} {
      allow read: if hasAccess(resource.data.ownerId);
      allow create: if hasAccess(request.resource.data.ownerId);
      allow update: if hasAccess(resource.data.ownerId) && hasAccess(request.resource.data.ownerId);
      allow delete: if hasAccess(resource.data.ownerId);
    }

    match /clients/{clientId} {
      allow read: if hasAccess(resource.data.ownerId);
      allow create: if hasAccess(request.resource.data.ownerId);
      allow update: if hasAccess(resource.data.ownerId) && hasAccess(request.resource.data.ownerId);
      allow delete: if hasAccess(resource.data.ownerId);
    }

    match /sales/{saleId} {
      allow read: if hasAccess(resource.data.ownerId);
      allow create: if hasAccess(request.resource.data.ownerId);
      allow update: if hasAccess(resource.data.ownerId) && hasAccess(request.resource.data.ownerId);
      // DELETE : autorisé si owner direct OU collaborateur du même tenant
      // On double la vérification pour éviter l'échec du get() interne
      allow delete: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid ||
        hasAccess(resource.data.ownerId)
      );
    }

    match /invoices/{invoiceId} {
      allow read: if hasAccess(resource.data.ownerId);
      allow create: if hasAccess(request.resource.data.ownerId);
      allow update: if hasAccess(resource.data.ownerId) && hasAccess(request.resource.data.ownerId);
      allow delete: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid ||
        hasAccess(resource.data.ownerId)
      );
    }

    match /counters/{counterId} {
      allow read, write: if isAuthenticated() && (
        counterId == 'invoices_' + request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         counterId == 'invoices_' + get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('ownerId', ''))
      );
    }

    match /categories/{categoryId} {
      allow read: if hasAccess(resource.data.ownerId);
      allow create: if hasAccess(request.resource.data.ownerId);
      allow update: if hasAccess(resource.data.ownerId) && hasAccess(request.resource.data.ownerId);
      allow delete: if hasAccess(resource.data.ownerId);
    }

    match /settings/{settingId} {
      allow read, write: if isAuthenticated() && (
        settingId == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('ownerId', '') == settingId)
      );
    }

    match /notes/{noteId} {
      allow read: if hasAccess(resource.data.ownerId);
      allow create: if hasAccess(request.resource.data.ownerId);
      allow update: if hasAccess(resource.data.ownerId) && hasAccess(request.resource.data.ownerId);
      allow delete: if hasAccess(resource.data.ownerId);
    }

    match /supplies/{supplyId} {
      allow read: if hasAccess(resource.data.ownerId);
      allow create: if hasAccess(request.resource.data.ownerId);
      allow update: if hasAccess(resource.data.ownerId) && hasAccess(request.resource.data.ownerId);
      allow delete: if hasAccess(resource.data.ownerId);
    }

    match /audit_logs/{logId} {
      // Tout utilisateur authentifié peut créer un log
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
      allow update, delete: if false;
    }

    // OTP codes — gérés uniquement par le serveur (admin SDK)
    match /otp_codes/{uid} {
      allow read, write: if false;
    }
  }
}
